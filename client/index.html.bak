</nav>

<!-- MAIN -->
<div id="main">
  <div class="topbar">
    <span class="topbar-title" id="topbar-title">Dashboard</span>
    <div class="topbar-right">
      <span id="topbar-time" class="mono"></span>
      <span class="badge-role">CDC Admin</span>
    </div>
  </div>

  <!-- ── DASHBOARD ── -->
  <div class="page active" id="page-dashboard">
    <div class="section-header">
      <div>
        <h2>Placement Overview</h2>
        <p>Branch-wise stats from <code>placement_dashboard</code> view · Live data</p>
      </div>
      <button class="btn btn-outline" onclick="loadDashboard()">↻ Refresh</button>
    </div>

    <div class="stats-row" id="overview-stats">
      <div class="stat-card c-accent">
        <div class="stat-label">Total Students</div>
        <div class="stat-value" id="s-total">—</div>
        <div class="stat-sub">Registered in system</div>
      </div>
      <div class="stat-card c-green">
        <div class="stat-label">Placed</div>
        <div class="stat-value" id="s-placed">—</div>
        <div class="stat-sub">Offers accepted</div>
      </div>
      <div class="stat-card c-blue">
        <div class="stat-label">Avg Package</div>
        <div class="stat-value" id="s-avg">—</div>
        <div class="stat-sub">LPA across branches</div>
      </div>
      <div class="stat-card c-orange">
        <div class="stat-label">Max Package</div>
        <div class="stat-value" id="s-max">—</div>
        <div class="stat-sub">Highest offer LPA</div>
      </div>
    </div>

    <div class="chart-grid">
      <div class="chart-card">
        <div class="chart-title">Placement % by Branch</div>
        <div class="chart-sub">From VIEW: placement_dashboard</div>
        <div class="bar-chart" id="branch-bar-chart"></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Company Offers Breakdown</div>
        <div class="chart-sub">From VIEW: company_stats</div>
        <div class="bar-chart" id="company-bar-chart"></div>
      </div>
    </div>

    <div class="table-wrap">
      <div class="table-header">
        <div>
          <div class="table-header-title">Branch-wise Placement Dashboard</div>
          <div class="table-header-sub">VIEW: placement_dashboard — aggregated with LEFT JOIN + GROUP BY</div>
        </div>
      </div>
      <div id="dashboard-table-body">
        <div class="loading"><div class="spinner"></div> Loading...</div>
      </div>
    </div>
  </div>

  <!-- ── STUDENTS ── -->
  <div class="page" id="page-students">
    <div class="section-header">
      <div>
        <h2>Students</h2>
        <p>All registered students · sorted by CPI descending</p>
      </div>
      <button class="btn btn-primary" onclick="openModal('add-student-modal')">+ Add Student</button>
    </div>
    <div class="table-wrap">
      <div class="table-header">
        <div>
          <div class="table-header-title">Student Registry</div>
          <div class="table-header-sub">TABLE: STUDENT · <span id="student-count">—</span> records</div>
        </div>
      </div>
      <div id="students-table">
        <div class="loading"><div class="spinner"></div> Loading...</div>
      </div>
    </div>
  </div>

  <!-- ── COMPANIES ── -->
  <div class="page" id="page-companies">
    <div class="section-header">
