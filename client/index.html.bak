        <button class="btn btn-outline" onclick="navigate('companies'); loadCompanies()">↻ Refresh</button>
        <button class="btn btn-primary" onclick="openModal('add-company-modal')">+ Add Company</button>
      </div>
    </div>
    <div id="companies-content">
      <div class="loading"><div class="spinner"></div> Loading...</div>
    </div>
  </div>

  <!-- ── APPLICATIONS ── -->
  <div class="page" id="page-applications">
    <div class="section-header">
      <div>
        <h2>Applications</h2>
        <p>All student applications · UNIQUE constraint on (student_id, role_id)</p>
      </div>
      <button class="btn btn-primary" onclick="openModal('new-application-modal')">+ New Application</button>
    </div>
    <div class="table-wrap">
      <div class="table-header">
        <div>
          <div class="table-header-title">Application Log</div>
          <div class="table-header-sub">TABLE: APPLICATION · status updates fire TRIGGER trg_check_cpi_before_apply</div>
        </div>
      </div>
      <div id="applications-table">
        <div class="loading"><div class="spinner"></div> Loading...</div>
      </div>
    </div>
  </div>

  <!-- ── OFFERS ── -->
  <div class="page" id="page-offers">
    <div class="section-header">
      <div>
        <h2>Offers</h2>
        <p>Placement offers · Accepting fires DB triggers</p>
      </div>
      <button class="btn btn-primary" onclick="openModal('new-offer-modal')">+ Create Offer</button>
    </div>
    <div class="trigger-box">
      <strong>⚡ DB Triggers on OFFER.acceptance_status → 'accepted':</strong><br>
      1. <strong>trg_auto_reject_on_acceptance</strong> — auto-rejects all other pending/shortlisted applications for this student<br>
      2. <strong>trg_close_role_when_full</strong> — closes the job role if accepted count ≥ openings<br>
      3. <strong>trg_auto_reject_on_acceptance</strong> — marks student eligible = FALSE (placed)
    </div>
    <div id="offers-content">
      <div class="loading"><div class="spinner"></div> Loading...</div>
    </div>
  </div>

  <!-- ── TRACKER ── -->
  <div class="page" id="page-tracker">
    <div class="section-header">
      <div>
        <h2>Application Tracker</h2>
