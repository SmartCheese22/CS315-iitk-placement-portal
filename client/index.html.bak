</div>

<script>
//const API = 'http://localhost:5000';
const API = 'https://placement-portal-api-6m2r.onrender.com';

// ── UTILS ──
function toast(msg, type='info') {
  const c = document.getElementById('toast-container');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  const icons = {success:'✓',error:'✕',info:'◈'};
  el.innerHTML = `<span>${icons[type]||'◈'}</span> ${msg}`;
  c.appendChild(el);
  setTimeout(()=>{ el.style.opacity='0'; el.style.transform='translateX(20px)'; el.style.transition='all 0.3s'; setTimeout(()=>el.remove(),300); }, 3500);
}

async function api(path, opts={}) {
  const r = await fetch(API+path, {headers:{'Content-Type':'application/json'}, ...opts});
  const d = await r.json();
  if(!r.ok) throw new Error(d.error || 'Request failed');
  return d;
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m=>{
  m.addEventListener('click', e=>{ if(e.target===m) m.classList.remove('open'); });
});

// ── STATUS PILLS ──
function statusPill(s) {
  const map = {
    applied:'pill-blue', shortlisted:'pill-yellow', offered:'pill-accent',
    rejected:'pill-red', accepted:'pill-green', declined:'pill-red',
    pending:'pill-yellow', pass:'pill-green', fail:'pill-red'
  };
  return `<span class="pill ${map[s]||'pill-muted'}">${s}</span>`;
}
function sectorPill(s) {
  const map = {Tech:'pill-blue',Finance:'pill-green',Core:'pill-orange',Consult:'pill-purple'};
  return `<span class="pill ${map[s]||'pill-muted'}">${s||'—'}</span>`;
}

// ── NAVIGATION ──
const pageTitles = {
  dashboard:'Dashboard', students:'Students', companies:'Companies & Roles',
  applications:'Applications', offers:'Offers', tracker:'Application Tracker', queries:'Interesting Queries'
};
function navigate(page) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  document.querySelector(`[data-page="${page}"]`).classList.add('active');
  document.getElementById('topbar-title').textContent = pageTitles[page];

  const loaders = {
    dashboard: loadDashboard, students: loadStudents, companies: loadCompanies,
    applications: loadApplications, offers: loadOffers, queries: ()=>runQuery(0)
  };
  if(loaders[page]) loaders[page]();
}

// Clock
setInterval(()=>{
  const t = new Date();
  document.getElementById('topbar-time').textContent =
    t.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
},1000);

// ── DASHBOARD ──
// ── DASHBOARD ──
async function loadDashboard() {
  try {
    const [dash, cstats] = await Promise.all([
      api('/application/dashboard'),
      api('/company/stats')
    ]);

    let total=0, placed=0, maxPkg=0, totalPkgSum=0, totalPlaced=0;
    dash.forEach(r=>{
      total += parseInt(r.total_students) || 0;
      placed += parseInt(r.placed_students) || 0;
      
      // Parse the MySQL strings into actual numbers
      const rMax = parseFloat(r.max_package_lpa) || 0;
      const rAvg = parseFloat(r.avg_package_lpa) || 0;
      
      if(rMax > maxPkg) maxPkg = rMax;
      if(rAvg && r.placed_students) { 
          totalPkgSum += rAvg * r.placed_students; 
          totalPlaced += r.placed_students; 
      }
    });
    
    document.getElementById('s-total').textContent = total;
    document.getElementById('s-placed').textContent = placed;
    document.getElementById('s-avg').textContent = totalPlaced ? (totalPkgSum/totalPlaced).toFixed(1) : '—';
    document.getElementById('s-max').textContent = maxPkg ? maxPkg.toFixed(1) : '—';

    // Branch bar chart
    const maxPct = Math.max(...dash.map(d=>parseFloat(d.placement_pct)||0), 1);
    const branchColors = ['#00d4aa','#0088ff','#f59e0b','#a855f7'];
    document.getElementById('branch-bar-chart').innerHTML = dash.map((d,i)=>`
      <div class="bar-row">
        <div class="bar-label">${d.branch}</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:${Math.max(((parseFloat(d.placement_pct)||0)/Math.max(maxPct,1))*100,2)}%;background:${branchColors[i%4]}">
            <span>${d.placed_students}/${d.total_students}</span>
          </div>
        </div>
        <div class="bar-pct">${d.placement_pct}%</div>
      </div>
    `).join('');

    // Company bar chart
    const maxOffers = Math.max(...cstats.map(c=>parseInt(c.total_offers)||0), 1);
    document.getElementById('company-bar-chart').innerHTML = cstats.slice(0,6).map((c,i)=>`
      <div class="bar-row">
        <div class="bar-label" style="font-size:10px;overflow:hidden;text-overflow:ellipsis">${c.company_name.length>8?c.company_name.slice(0,8)+'..':c.company_name}</div>
        <div class="bar-track">
          <div class="bar-fill" style="width:${Math.max(((parseInt(c.total_offers)||0)/maxOffers)*100,2)}%;background:${branchColors[(i+2)%4]}">
            <span>${c.total_offers||0}</span>
          </div>
        </div>
        <div class="bar-pct">${c.accepted_offers||0} acc</div>
      </div>
    `).join('');

    // Dashboard table
    document.getElementById('dashboard-table-body').innerHTML = `
      <table>
        <thead><tr>
          <th>Branch</th><th>Total Students</th><th>Placed</th>
          <th>Placement %</th><th>Avg Package (LPA)</th><th>Max Package (LPA)</th>
        </tr></thead>
        <tbody>${dash.map(r=>`
          <tr>
            <td><strong>${r.branch}</strong></td>
            <td class="mono">${r.total_students}</td>
            <td class="mono">${r.placed_students}</td>
            <td>
              <div class="cpi-bar">
                <div style="flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden">
                  <div style="width:${r.placement_pct}%;height:100%;background:var(--accent);border-radius:3px"></div>
                </div>
                <span class="mono" style="font-size:11px;color:var(--accent);width:42px;text-align:right">${r.placement_pct}%</span>
              </div>
            </td>
            <td class="mono">${r.avg_package_lpa ? r.avg_package_lpa+' LPA' : '<span style="color:var(--muted)">—</span>'}</td>
            <td class="mono">${r.max_package_lpa ? '<span style="color:var(--accent)">'+r.max_package_lpa+' LPA</span>' : '<span style="color:var(--muted)">—</span>'}</td>
          </tr>
        `).join('')}</tbody>
      </table>`;
  } catch(e) { toast(e.message,'error'); }
}

// ── STUDENTS ──
async function loadStudents() {
  try {
    const students = await api('/student');
    document.getElementById('student-count').textContent = students.length;
    document.getElementById('students-table').innerHTML = `
      <table>
        <thead><tr>
          <th>#</th><th>Roll No</th><th>Name</th><th>Branch</th>
          <th>CPI</th><th>Grad Year</th><th>Status</th>
        </tr></thead>
        <tbody>${students.map((s,i)=>`
          <tr>
            <td class="muted-cell mono">${i+1}</td>
            <td class="mono" style="color:var(--accent2)">${s.roll_no}</td>
            <td><strong>${s.name}</strong></td>
            <td>${s.branch}</td>
            <td>
              <div class="cpi-bar" style="gap:6px">
                <div class="cpi-pip" style="background:${s.cpi>=8.5?'var(--green)':s.cpi>=7?'var(--yellow)':'var(--red)'}"></div>
                <span class="mono" style="color:${s.cpi>=8.5?'var(--green)':s.cpi>=7?'var(--yellow)':'var(--red)'}">${s.cpi}</span>
              </div>
            </td>
            <td class="mono muted-cell">${s.grad_year}</td>
            <td>${s.eligible ? '<span class="pill pill-green">Eligible</span>' : '<span class="pill pill-accent">Placed</span>'}</td>
          </tr>
        `).join('')}</tbody>
      </table>`;
  } catch(e) { toast(e.message,'error'); }
}

async function addStudent() {
  try {
    await api('/student', {
      method:'POST',
      body: JSON.stringify({
        roll_no: document.getElementById('s-roll').value.trim(),
        name: document.getElementById('s-name').value.trim(),
        email : document.getElementById('s-email').value.trim(),
        branch: document.getElementById('s-branch').value,
        cpi: parseFloat(document.getElementById('s-cpi').value),
        grad_year: parseInt(document.getElementById('s-grad').value)
      })
    });
    closeModal('add-student-modal');
    toast('Student added successfully','success');
    loadStudents();
  } catch(e) { toast(e.message,'error'); }
}

// ── COMPANIES ──
async function loadCompanies() {
  try {
    const [companies, stats] = await Promise.all([api('/company'), api('/company/stats')]);
    const statsMap = {};
    stats.forEach(s=>{ statsMap[s.company_name] = s; });

    const html = companies.map(c=>{
      const s = statsMap[c.name] || {};
      return `
        <div class="table-wrap" style="margin-bottom:16px;">
          <div class="table-header">
            <div>
              <div class="table-header-title" style="display:flex;align-items:center;gap:10px;">
                ${c.name} ${sectorPill(c.sector)}
              </div>
              <div class="table-header-sub">
                Min CPI: <span style="color:var(--yellow)">${c.min_cpi}</span> ·
                HR: <span style="color:var(--accent2)">${c.hr_contact||'—'}</span> ·
                Roles: ${s.total_roles||0} ·
                Offers: ${s.total_offers||0} ·
                Accepted: ${s.accepted_offers||0} ·
                Avg Pkg: ${s.avg_package_offered ? s.avg_package_offered+' LPA' : '—'}
              </div>
            </div>
            <button class="btn btn-outline btn-sm" onclick="openAddRole(${c.company_id},'${c.name}')">+ Add Role</button>
          </div>
          <div id="roles-${c.company_id}">
            <div class="loading"><div class="spinner"></div></div>
          </div>
        </div>`;
    }).join('');

    document.getElementById('companies-content').innerHTML = html;
    companies.forEach(c=>loadRoles(c.company_id));
  } catch(e) { toast(e.message,'error'); }
}

async function loadRoles(company_id) {
  try {
    const roles = await api(`/company/${company_id}/roles`);
    const el = document.getElementById('roles-'+company_id);
    if(!roles.length) { el.innerHTML = '<div class="empty" style="padding:20px"><div class="empty-text" style="color:var(--muted)">No roles added yet</div></div>'; return; }
    el.innerHTML = `
      <table>
        <thead><tr><th>ID</th><th>Title</th><th>Package</th><th>Location</th><th>Openings</th><th>Status</th></tr></thead>
        <tbody>${roles.map(r=>`
          <tr>
            <td class="mono muted-cell">#${r.role_id}</td>
            <td><strong>${r.title}</strong></td>
            <td class="mono" style="color:var(--accent)">${r.package_lpa} LPA</td>
            <td class="muted-cell">${r.location||'—'}</td>
            <td class="mono">${r.openings}</td>
            <td>${r.is_open ? '<span class="pill pill-green">Open</span>' : '<span class="pill pill-muted">Closed</span>'}</td>
          </tr>
        `).join('')}</tbody>
      </table>`;
  } catch(e) {}
}

function openAddRole(company_id, name) {
  document.getElementById('role-company-id').value = company_id;
  document.querySelector('#add-role-modal .modal-head h3').textContent = `Add Role — ${name}`;
  openModal('add-role-modal');
}

async function addCompany() {
  try {
    await api('/company', {
      method:'POST',
      body: JSON.stringify({
        name: document.getElementById('c-name').value.trim(),
        sector: document.getElementById('c-sector').value,
        hr_contact: document.getElementById('c-hr').value.trim(),
        min_cpi: parseFloat(document.getElementById('c-cpi').value)||0
      })
    });
    closeModal('add-company-modal');
    toast('Company added','success');
    loadCompanies();
  } catch(e) { toast(e.message,'error'); }
}

async function addRole() {
  try {
    const cid = document.getElementById('role-company-id').value;
    await api(`/company/${cid}/roles`, {
      method:'POST',
      body: JSON.stringify({
        title: document.getElementById('r-title').value.trim(),
        package_lpa: parseFloat(document.getElementById('r-pkg').value),
        location: document.getElementById('r-loc').value.trim(),
        openings: parseInt(document.getElementById('r-open').value)
      })
    });
    closeModal('add-role-modal');
    toast('Role added','success');
    loadRoles(cid);
  } catch(e) { toast(e.message,'error'); }
}

// ── APPLICATIONS ──
async function loadApplications() {
  try {
    const apps = await api('/application');
    document.getElementById('applications-table').innerHTML = `
      <table>
        <thead><tr>
          <th>App ID</th><th>Student</th><th>Roll No</th>
          <th>Company</th><th>Role</th><th>Package</th>
          <th>Status</th><th>Applied</th><th>Actions</th>
        </tr></thead>
        <tbody>${apps.map(a=>`
          <tr>
            <td class="mono muted-cell">#${a.app_id}</td>
            <td><strong>${a.student_name}</strong></td>
            <td class="mono" style="color:var(--accent2)">${a.roll_no}</td>
            <td>${a.company_name}</td>
            <td>${a.role_title}</td>
            <td class="mono" style="color:var(--accent)">${a.package_lpa} LPA</td>
            <td id="app-status-${a.app_id}">${statusPill(a.status)}</td>
            <td class="muted-cell mono" style="font-size:10px">${a.applied_date?.slice(0,10)||'—'}</td>
            <td>
              <div style="display:flex;gap:4px;flex-wrap:wrap">
                ${['shortlisted','rejected'].map(st=>`
                  <button class="btn btn-outline btn-sm" onclick="updateAppStatus(${a.app_id},'${st}')">${st}</button>
                `).join('')}
                <button class="btn btn-outline btn-sm" onclick="openInterviewModal(${a.app_id})">+ Round</button>
              </div>
            </td>
          </tr>
        `).join('')}</tbody>
      </table>`;
  } catch(e) { toast(e.message,'error'); }
}

async function updateAppStatus(app_id, status) {
  try {
    await api(`/application/${app_id}/status`, {method:'PUT', body:JSON.stringify({status})});
    document.getElementById(`app-status-${app_id}`).innerHTML = statusPill(status);
    toast(`Status → ${status}`,'success');
  } catch(e) { toast(e.message,'error'); }
}

function openInterviewModal(app_id) {
  document.getElementById('ir-app-id').value = app_id;
  openModal('interview-modal');
}

async function addInterviewRound() {
  try {
    const app_id = document.getElementById('ir-app-id').value;
    await api('/interview', {
      method:'POST',
      body: JSON.stringify({
        app_id: parseInt(app_id),
        round_no: parseInt(document.getElementById('ir-round-no').value),
        round_type: document.getElementById('ir-type').value,
        result: document.getElementById('ir-result').value,
        round_date: document.getElementById('ir-date').value || null
      })
    });
    closeModal('interview-modal');
    toast('Interview round added','success');
  } catch(e) { toast(e.message,'error'); }
}

async function populateApplicationModal() {
  const [students, roles] = await Promise.all([api('/student'), api('/company/roles/open')]);
  document.getElementById('app-student').innerHTML = students.map(s=>`<option value="${s.student_id}">${s.name} (${s.roll_no}) — CPI ${s.cpi}</option>`).join('');
  document.getElementById('app-role').innerHTML = roles.map(r=>`<option value="${r.role_id}">${r.company_name} — ${r.title} (${r.package_lpa} LPA)</option>`).join('');
}

async function submitApplication() {
  try {
    await api('/application', {
      method:'POST',
      body: JSON.stringify({
        student_id: parseInt(document.getElementById('app-student').value),
        role_id: parseInt(document.getElementById('app-role').value)
      })
    });
    closeModal('new-application-modal');
    toast('Application submitted — CPI trigger passed ✓','success');
    loadApplications();
  } catch(e) { toast(e.message,'error'); }
}

// ── OFFERS ──
async function loadOffers() {
  try {
    const offers = await api('/offer');
    if(!offers.length) {
      document.getElementById('offers-content').innerHTML = `<div class="empty"><div class="empty-icon">◎</div><div class="empty-text">No offers yet</div></div>`;
      return;
    }
    document.getElementById('offers-content').innerHTML = `
      <div class="offer-grid">${offers.map(o=>`
        <div class="offer-card ${o.acceptance_status}">
          <div class="offer-top">
            <div>
              <div class="offer-company">${o.company}</div>
              <div class="offer-role">${o.role}</div>
            </div>
            <div style="text-align:right">
              <div class="offer-pkg">${o.package_offered}</div>
              <div class="offer-pkg-sub">LPA</div>
            </div>
          </div>
          <div class="offer-student">
            <div class="tracker-avatar" style="width:36px;height:36px;font-size:13px">${o.student_name.charAt(0)}</div>
            <div class="offer-student-info">
              <div class="offer-student-name">${o.student_name}</div>
              <div class="offer-student-sub">${o.roll_no} · ${o.branch}</div>
            </div>
            ${statusPill(o.acceptance_status)}
          </div>
          <div style="font-size:10px;color:var(--muted);margin-bottom:12px">
            Offer Date: ${o.offer_date?.slice(0,10)} · HR: ${o.hr_contact||'—'}
          </div>
          ${o.acceptance_status === 'pending' ? `
            <div class="offer-actions">
              <button class="btn btn-success btn-sm" style="flex:1" onclick="acceptOffer(${o.offer_id})">
                ✓ Accept — Fire Triggers
              </button>
              <button class="btn btn-danger btn-sm" onclick="declineOffer(${o.offer_id})">✕ Decline</button>
            </div>
          ` : `<div style="font-size:11px;color:var(--muted)">No actions available</div>`}
        </div>
      `).join('')}</div>`;
  } catch(e) { toast(e.message,'error'); }
}

async function acceptOffer(offer_id) {
  try {
    const r = await api(`/offer/${offer_id}/accept`, {method:'PUT'});
    toast('Offer accepted! All 3 triggers fired 🔥','success');
    loadOffers();
  } catch(e) { toast(e.message,'error'); }
}

async function declineOffer(offer_id) {
  try {
    await api(`/offer/${offer_id}/decline`, {method:'PUT'});
    toast('Offer declined','info');
    loadOffers();
  } catch(e) { toast(e.message,'error'); }
}

async function populateOfferModal() {
  const [students, roles] = await Promise.all([api('/student'), api('/company/roles/open')]);
  document.getElementById('offer-student').innerHTML = students
    .filter(s=>s.eligible)
    .map(s=>`<option value="${s.student_id}">${s.name} (${s.roll_no})</option>`).join('');
  document.getElementById('offer-role').innerHTML = roles.map(r=>`<option value="${r.role_id}">${r.company_name} — ${r.title}</option>`).join('');
}

async function createOffer() {
  try {
    await api('/offer', {
      method:'POST',
      body: JSON.stringify({
        student_id: parseInt(document.getElementById('offer-student').value),
        role_id: parseInt(document.getElementById('offer-role').value),
        package_offered: parseFloat(document.getElementById('offer-pkg').value)
      })
    });
    closeModal('new-offer-modal');
    toast('Offer created','success');
    loadOffers();
  } catch(e) { toast(e.message,'error'); }
}

// ── TRACKER ──
async function runTracker() {
  const roll = document.getElementById('tracker-input').value.trim();
  if(!roll) return toast('Enter a roll number','error');
  try {
    const [student, apps] = await Promise.all([api(`/student/${roll}`), api(`/student/${roll}/tracker`)]);
    const el = document.getElementById('tracker-result');
    el.classList.add('show');
    el.innerHTML = `
      <div class="tracker-student-header">
        <div class="tracker-avatar">${student.name.charAt(0)}</div>
        <div>
          <div class="tracker-name">${student.name}</div>
          <div class="tracker-meta">${student.roll_no} · ${student.branch} · CPI ${student.cpi} · ${student.grad_year}</div>
          <div style="margin-top:8px">${student.eligible ? '<span class="pill pill-green">Eligible</span>' : '<span class="pill pill-accent">Placed ✓</span>'}</div>
        </div>
      </div>
      ${apps.length ? `
        <div class="table-wrap">
          <div class="table-header">
            <div class="table-header-title">Application History</div>
            <div class="table-header-sub">VIEW: application_tracker · ${apps.length} application(s)</div>
          </div>
          <table>
            <thead><tr>
              <th>Company</th><th>Role</th><th>Package</th>
              <th>App Status</th><th>Applied</th><th>Latest Round</th><th>Round Result</th>
            </tr></thead>
            <tbody>${apps.map(a=>`
              <tr>
                <td><strong>${a.company_name}</strong></td>
                <td>${a.role_title}</td>
                <td class="mono" style="color:var(--accent)">${a.role_package} LPA</td>
                <td>${statusPill(a.app_status)}</td>
                <td class="mono muted-cell" style="font-size:10px">${a.applied_date?.slice(0,10)||'—'}</td>
                <td class="muted-cell">${a.latest_round_type ? `Round ${a.latest_round} — ${a.latest_round_type}` : '—'}</td>
                <td>${a.latest_round_result ? statusPill(a.latest_round_result) : '<span class="muted-cell">—</span>'}</td>
              </tr>
            `).join('')}</tbody>
          </table>
        </div>
      ` : '<div class="empty"><div class="empty-text">No applications found for this student</div></div>'}
    `;
  } catch(e) { toast(e.message,'error'); }
}

// ── QUERIES ──
const queryDefs = [
  {
    label: 'Tech Pass / HR Fail',
    desc: '<strong>Query 1:</strong> Students who passed Technical round but subsequently failed HR round. Uses correlated subquery on INTERVIEW_ROUND with JOIN across APPLICATION → STUDENT → JOB_ROLE → COMPANY.',
    url: '/application/queries/tech-pass-hr-fail',
    cols: ['Name','Roll No','Branch','CPI','Company','Role'],
    keys: ['name','roll_no','branch','cpi','company_name','role_title']
  },
  {
    label: 'No Offer ≥3 Apps',
    desc: '<strong>Query 2:</strong> Students with 3 or more applications but no accepted offer. Uses NOT IN subquery + GROUP BY + HAVING. Highlights students actively applying without success.',
    url: '/application/queries/no-offer',
    cols: ['Name','Roll No','Branch','CPI','Total Applications'],
    keys: ['name','roll_no','branch','cpi','total_applications']
  },
  {
    label: 'Company CPI Rank',
    desc: '<strong>Query 3 (Window Function):</strong> Ranks students within each job role by CPI using <code style="color:var(--accent)">RANK() OVER (PARTITION BY role_id ORDER BY cpi DESC)</code>. Enter company ID below.',
    url: null,
    cols: ['Name','Roll No','Branch','CPI','Role','Status','CPI Rank'],
    keys: ['name','roll_no','branch','cpi','role_title','status','cpi_rank'],
    needsInput: true
  }
];

let currentQuery = 0;
async function switchQuery(i) {
  currentQuery = i;
  document.querySelectorAll('.qtab').forEach((t,idx)=>t.classList.toggle('active', idx===i));
  const q = queryDefs[i];
  document.getElementById('query-desc').innerHTML = q.desc +
    (q.needsInput ? `<br><br><div style="display:flex;gap:8px;margin-top:8px"><input class="form-input" id="q-company-id" placeholder="Company ID (1-8)" style="max-width:200px"/><button class="btn btn-primary btn-sm" onclick="runQuery(${i})">Run Query</button></div>` : '');
  await runQuery(i);
}

async function runQuery(i) {
  const q = queryDefs[i];
  const el = document.getElementById('query-result');
  el.innerHTML = '<div class="loading"><div class="spinner"></div> Running query...</div>';
  try {
    let url = q.url;
    if(q.needsInput) {
      const cid = document.getElementById('q-company-id')?.value || 1;
      url = `/application/queries/company-ranking/${cid}`;
    }
    const rows = await api(url);
    if(!rows.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">◎</div><div class="empty-text">No results</div></div>'; return; }
    el.innerHTML = `
      <div class="table-wrap">
        <div class="table-header">
          <div class="table-header-title">${q.label}</div>
          <div class="table-header-sub">${rows.length} row(s) returned</div>
        </div>
        <table>
          <thead><tr>${q.cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead>
          <tbody>${rows.map(r=>`
            <tr>${q.keys.map(k=>{
              if(k==='status') return `<td>${statusPill(r[k])}</td>`;
              if(k==='cpi_rank') {
                const cls = r[k]===1?'rank-1':r[k]===2?'rank-2':r[k]===3?'rank-3':'rank-n';
                return `<td><span class="rank-badge ${cls}">${r[k]}</span></td>`;
              }
              if(k==='cpi') return `<td class="mono" style="color:${r[k]>=8.5?'var(--green)':r[k]>=7?'var(--yellow)':'var(--red)'}">${r[k]}</td>`;
              return `<td class="${['roll_no','cpi','total_applications'].includes(k)?'mono':''}">${r[k]??'—'}</td>`;
            }).join('')}</tr>
          `).join('')}</tbody>
        </table>
      </div>`;
  } catch(e) { toast(e.message,'error'); el.innerHTML = `<div class="empty"><div class="empty-text" style="color:var(--red)">${e.message}</div></div>`; }
}

// ── MODAL OPENERS WITH POPULATION ──
const origOpenModal = openModal;
window.openModal = function(id) {
  if(id==='new-application-modal') populateApplicationModal();
  if(id==='new-offer-modal') populateOfferModal();
  document.getElementById(id).classList.add('open');
};

// ── BOOT ──
loadDashboard();
// Init query desc
switchQuery(0);
</script>
</body>
</html>
