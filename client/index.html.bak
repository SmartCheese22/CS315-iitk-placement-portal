      </div>
    </div>
    <div class="tracker-search">
      <input class="form-input" id="tracker-input" placeholder="Enter Roll No (e.g. 22B0118)..." onkeydown="if(event.key==='Enter') runTracker()"/>
      <button class="btn btn-primary" onclick="runTracker()">Search →</button>
    </div>
    <div class="tracker-result" id="tracker-result"></div>
  </div>

  <!-- ── QUERIES ── -->
  <div class="page" id="page-queries">
    <div class="section-header">
      <div>
        <h2>Interesting Queries</h2>
        <p>Complex SQL — subqueries, window functions, aggregates</p>
      </div>
    </div>
    <div class="query-tabs">
      <div class="qtab active" onclick="switchQuery(0)">Tech Pass / HR Fail</div>
      <div class="qtab" onclick="switchQuery(1)">No Offer ≥3 Apps</div>
      <div class="qtab" onclick="switchQuery(2)">Company CPI Rank</div>
    </div>
    <div id="query-desc" class="trigger-box" style="margin-bottom:16px;"></div>
    <div id="query-result">
      <div class="loading"><div class="spinner"></div> Loading...</div>
    </div>
  </div>

</div><!-- end #main -->

